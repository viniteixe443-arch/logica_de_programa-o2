programa {
  funcao inicio() {
  inteiro numero1, numero2, soma, resultado

  escreva("Informe o primeiro número: ")
  leia(numero1)

  escreva("Informe o segundo número: ")
  leia(numero2)

soma = numero1 + numero2

se(soma < 10 ){
    escreva( soma + 5)
}senao se(soma > 10){
    escreva(soma - 7)
}
 

}
}