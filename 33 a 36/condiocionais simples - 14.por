programa {
  funcao inicio() {
  inteiro valor1,valor2

  escreva("informe  o priemeiro valor: ")
  leia(valor1)   
  escreva("informe  o segundo valor: ")
  leia(valor2)

  se(valor1 > valor2){
    escreva("O primeiro valor é maior")
  }senao se(valor2 >  valor1){
    escreva("O segundo valor é maior")
  }   
  }
}
