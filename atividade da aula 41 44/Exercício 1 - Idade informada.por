programa {
  funcao inicio() {
    inteiro idade
    escreva("Informe a idade: ")
    leia(idade)
  
    escreva("Idade informada: ", idade)
    // Erro do código: Não possuia o comando escreva para o usuário informar uma idade e também possuia um 0 no local onde a variável idade deveria estar.
    //Solução do código: Aficionar o comando "escreva("informe a idade: ")" e substituir o 0 pela variável "idade"
  }
}
