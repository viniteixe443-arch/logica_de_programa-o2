programa {
  funcao inicio() {
    inteiro numero [4] = {1,2,3,4}
    inteiro somaDosValores
    inteiro multiplicacao
    inteiro diferenca

    


    somaDosValores = numero[0] + numero[3]

    multiplicacao = numero[1] * numero[2]

    diferenca = numero[2] - numero[0]

    escreva("A soma dos valores é de: ",somaDosValores,"\n")
    escreva("A multiplicação dos valores é de: ",multiplicacao,"\n")
    escreva("A diferença dos valores é de: ",diferenca,"\n")

  }
}
