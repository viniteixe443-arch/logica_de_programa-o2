programa {
  funcao inicio() {
    inteiro numero [5]

    escreva("Digite somente os valores mostrados: 0, 1 , 2: ")
    leia(numero[0])

    escreva("Digite somente os valores mostrados: 0, 1 , 2: ")
    leia(numero[1])

    escreva("Digite somente os valores mostrados: 0, 1 , 2: ")
    leia(numero[2])

    escreva(numero[0],"\n")
    escreva(numero[1],"\n")
    escreva(numero[2],"\n")
  }
}
